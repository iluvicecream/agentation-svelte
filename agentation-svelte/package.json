{
  "name": "agentation-svelte",
  "version": "0.1.0",
  "description": "Svelte 5 toolbar for visual feedback annotations",
  "license": "PolyForm-Shield-1.0.0",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
